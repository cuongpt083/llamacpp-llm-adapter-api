# ==============================================================================
# LLM MESSAGE NORMALIZATION ADAPTER - CONFIGURATION SAMPLE
# MẪU CẤU HÌNH ADAPTER CHUẨN HÓA TIN NHẮN LLM
# ==============================================================================
# This file contains the environment variables used by the Adapter API.
# Copy this file to '.env' and modify the values to match your setup.
# Tệp này chứa các biến môi trường được sử dụng bởi Adapter API.
# Sao chép tệp này thành '.env' và chỉnh sửa các giá trị phù hợp với hệ thống.

# ------------------------------------------------------------------------------
# UPSTREAM LLAMA.CPP SERVER SETTINGS / CẤU HÌNH MÁY CHỦ LLAMA.CPP
# ------------------------------------------------------------------------------

# The base URL of the llama.cpp server running with --api or -cb flags.
# URL cơ sở của máy chủ llama.cpp đang chạy với tham số --api hoặc -cb.
# Default: http://127.0.0.1:8080
UPSTREAM_BASE_URL=http://127.0.0.1:8080


# ------------------------------------------------------------------------------
# ADAPTER ENGINE SETTINGS / CẤU HÌNH BỘ MÁY ADAPTER
# ------------------------------------------------------------------------------

# Enable or disable the debug normalization endpoint (/v1/chat/completions:normalize).
# Useful for inspecting how the adapter transforms messages without calling the LLM.
# Bật hoặc tắt endpoint debug chuẩn hóa.
# Hữu ích để kiểm tra cách adapter chuyển đổi tin nhắn mà không cần gọi LLM.
# Default: true
ENABLE_DEBUG_ENDPOINTS=true

# Whether to log the full content of the normalized messages before forwarding.
# Set to 'false' in production if you have high traffic to save disk space.
# Có ghi log nội dung đầy đủ của tin nhắn đã chuẩn hóa trước khi chuyển tiếp hay không.
# Đặt thành 'false' trong môi trường thực tế nếu có lưu lượng truy cập cao để tiết kiệm dung lượng.
# Default: true
LOG_NORMALIZED_REQUESTS=true


# ------------------------------------------------------------------------------
# API SETTINGS / CẤU HÌNH API
# ------------------------------------------------------------------------------

# The prefix for the API routes. 
# Tiền tố cho các đường dẫn API.
# Default: /v1
API_V1_STR=/v1

# The name of the project, used in OpenAPI documentation.
# Tên dự án, được sử dụng trong tài liệu OpenAPI.
# Default: llamacpp-llm-adapter-api
PROJECT_NAME=llamacpp-llm-adapter-api


# ------------------------------------------------------------------------------
# DEPLOYMENT SETTINGS / CẤU HÌNH TRIỂN KHAI
# ------------------------------------------------------------------------------

# These are standard Uvicorn parameters if running via 'uvicorn app.main:app'
# Đây là các tham số Uvicorn tiêu chuẩn nếu chạy qua lệnh 'uvicorn app.main:app'

# Port to listen on / Cổng lắng nghe
# PORT=8000

# Host to bind to / Địa chỉ IP lắng nghe
# HOST=0.0.0.0

# Number of worker processes / Số lượng tiến trình worker
# WORKERS=4
